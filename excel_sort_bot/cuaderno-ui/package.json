{
  "name": "cuaderno-ui",
  "version": "0.1.0",
  "private": true,
  "main": "electron.js",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "dev:stack": "concurrently -n api,web -c blue,green \"python3 ../rte_server.py\" \"next dev --hostname 127.0.0.1\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "desktop": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 -t 30000 && sleep 2 && ./start-electron.sh\"",
    "desktop:all": "concurrently \"python3 ../rte_server.py\" \"npm run dev\" \"wait-on http://localhost:3000 -t 30000 && sleep 2 && ./start-electron.sh\""
  },
  "dependencies": {
    "lucide-react": "^0.563.0",
    "next": "15.5.14",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^40.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.14",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.3"
  }
}
