                "year": {
                    "cell": "M1"
                },
                "explotacion": {
                    "cell": "E1"
                }
            }
        },
        "inf.gral 2": {
            "purpose": "Operadores, asesores, ROPO",
            "type": "table",
            "header_row": 9,
