            "columns": {
                "fecha": 1,
                "material_analizado": 2,
                "cultivo_muestreado": 3,
                "nro_boletin": 4,
                "laboratorio_nombre": 5,
                "laboratorio_direccion": 6,
                "sustancias_detectadas": 7
            }
        },
        "reg. cosecha": {
            "purpose": "Registro de cosecha / salida",
            "type": "table",
            "header_row": 10,
            "data_start_row": 11,
