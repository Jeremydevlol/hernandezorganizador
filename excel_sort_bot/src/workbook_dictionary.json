    "actions_schema": {
        "ADD_TREATMENT": {
            "target_sheet": "inf.trat 1",
            "required": [
                "id_parcelas",
                "especie",
                "superficie_tratada",
                "fecha",
                "producto",
                "dosis"
            ],
            "optional": [
                "variedad",
                "problema_fito",
                "nro_registro",
                "observaciones"
            ]
        },
        "ADD_FERTILIZATION": {
            "target_sheet": "reg.fert.",
            "required": [
                "fecha_inicio",
                "parcelas",
                "tipo_abono",
                "dosis"
            ],
            "optional": [
                "fecha_fin",
                "especie",
                "riqueza_n",
                "riqueza_p",
                "riqueza_k"
            ]
        },
        "ADD_HARVEST": {
            "target_sheet": "reg. cosecha",
            "required": [
                "fecha",
                "producto",
                "cantidad_kg",
                "parcelas_origen"
            ],
            "optional": [
                "albaran",
                "lote",
                "cliente_nombre"
            ]
        },
        "ADD_SEEDING": {
            "target_sheet": "inf.trat 3",
            "required": [
                "fecha_siembra",
                "id_parcelas",
                "cultivo",
                "superficie_sembrada"
            ],
            "optional": [
                "cantidad_semilla",
                "producto"
            ]
        }
    },
    "validation_rules": {
        "date_format": "DD/MM/YYYY",
        "dose_format": "X,XX l|kg",
        "superficie_min": 0.01,
        "id_parcelas_must_exist": true
    }
}