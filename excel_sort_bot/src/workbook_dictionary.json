                "cliente_nif": 8,
                "cliente_direccion": 9,
                "rgseaa": 10
            }
        },
        "reg.fert.": {
            "purpose": "Registro de fertilización",
            "type": "table",
            "header_row": 10,
            "data_start_row": 11,
            "columns": {
                "fecha_inicio": 1,
                "fecha_fin": 2,
                "parcelas": 3,
                "especie": 4,
                "variedad": 5,
                "tipo_abono": 6,
                "albaran": 7,
                "riqueza_n": 8,
                "riqueza_p": 9,
                "riqueza_k": 10,
                "dosis": 11,
                "tipo_fertilizacion": 12,
                "observaciones": 13
            }
        }
