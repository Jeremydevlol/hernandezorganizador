            "required_fields": [
                "id_parcelas",
                "especie",
                "superficie_tratada",
                "fecha",
                "producto",
                "dosis"
            ],
            "defaults": {
                "aplicador": 1,
                "equipo": 1,
                "eficacia": "BUENA"
