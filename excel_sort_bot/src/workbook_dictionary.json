            "columns": {
                "nro_orden": 1,
                "nombre": 2,
                "nif": 3,
                "ropo": 4,
                "basico": 5,
                "cualificado": 6,
                "fumigador": 7,
                "piloto": 8,
                "asesor": 9
            }
        },
        "2.1. DATOS PARCELAS": {
